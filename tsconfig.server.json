{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "incremental": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx"
  },
  "include": [
    "src/server/**/*.ts",
    "src/shared/**/*.ts",
    "src/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "src/**/*.test.ts"]
}
